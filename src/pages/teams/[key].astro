---
import Base from '../../layouts/Base.astro';
import meta from '../../../data/teams-meta.json';

const M = meta as any;
export function getStaticPaths() {
  const mm = (meta as any).managers as any[];
  return mm.map((m) => ({ params: { key: m.key }, props: { m } }));
}
const { m } = Astro.props;
const years = ((M.seasonsByMgr[m.key] || []) as number[]).slice().sort((a, b) => b - a);
const mgrNames = Object.fromEntries(M.managers.map((x: any) => [x.key, x.name]));
const schedulesByYear: Record<string, any> = {};
const teamNamesByYear: Record<string, any> = {};
for (const y of years) { schedulesByYear[y] = (M.schedules[y] && M.schedules[y][m.key]) || []; teamNamesByYear[y] = M.teamNames[y] || {}; }
const clientData = { key: m.key, name: m.name, years, schedulesByYear, teamNamesByYear, mgrNames };
const a = m.allTime, p = m.playoff;
---
<Base title={m.name} subtitle={`${m.status === 'alumni' ? 'Alumni' : 'Manager'}${m.currentTeam ? ' · ' + m.currentTeam : ''} · since ’${String(m.since).slice(-2)}`}>
  <a href="/teams/" class="tm-back">← All Teams</a>

  <div class="card tm-ovcard">
    <div class="tm-ov">
      <div class="tm-st"><div class="tm-v">{a.w}–{a.l}</div><div class="tm-l">All-Time</div></div>
      <div class="tm-st"><div class="tm-v">{a.winPct.toFixed(1)}%</div><div class="tm-l">Win %</div></div>
      <div class="tm-st"><div class="tm-v">{a.seasons}</div><div class="tm-l">Seasons</div></div>
      <div class="tm-st"><div class="tm-v">{a.playoffAppearances}</div><div class="tm-l">Playoffs</div></div>
      {p && <div class="tm-st"><div class="tm-v">{p.w}–{p.l}</div><div class="tm-l">Post-season</div></div>}
      <div class="tm-st"><div class="tm-v">{a.titles ? `${a.titles} 🏆` : '0'}</div><div class="tm-l">Titles</div></div>
    </div>
  </div>

  <div class="tm-ctrl">
    <label for="seasonSel">Season</label>
    <select id="seasonSel">{years.map((y) => <option value={y}>{y}</option>)}</select>
    <span id="teamName" class="sub"></span>
  </div>

  <div id="body"><div class="sub" style="padding:20px 0">Loading season…</div></div>

  <script is:inline define:vars={{ D: clientData }}>
    (() => {
      const cache = {};
      const $ = (id) => document.getElementById(id);
      const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const teamOf = (yr, mk) => (D.teamNamesByYear[yr] && D.teamNamesByYear[yr][mk]) || D.mgrNames[mk] || mk;
      const nameOf = (mk) => D.mgrNames[mk] || mk;
      const posOrder = { QB: 1, RB: 2, WR: 3, TE: 4, 'W/R/T': 5, K: 6, DEF: 7 };

      async function loadSeason(yr) {
        if (!cache[yr]) { const r = await fetch('/lineups/' + yr + '.json'); cache[yr] = await r.json(); }
        return cache[yr];
      }

      function rosterHtml(yr) {
        const wks = (cache[yr] && cache[yr][D.key]) || {};
        const byPl = {};
        for (const wk of Object.keys(wks)) for (const [slot, nm, pts] of wks[wk].s) {
          if (!byPl[nm]) byPl[nm] = { pts: 0, st: 0, pos: null };
          const b = byPl[nm]; b.pts += pts; b.st++;
          if (b.pos === null) b.pos = slot; else if (b.pos === 'W/R/T' && slot !== 'W/R/T') b.pos = slot;
        }
        const roster = Object.entries(byPl).sort((x, y) => { const px = posOrder[x[1].pos] || 8, py = posOrder[y[1].pos] || 8; return px !== py ? px - py : y[1].pts - x[1].pts; });
        if (!roster.length) return '';
        const N = 10, extra = roster.length - N;
        return '<div class="card"><div class="tm-eyebrow">' + yr + ' Roster — season fantasy points</div>'
          + '<div class="table-scroll"><table class="stbl tm-rost' + (extra > 0 ? ' collapsed' : '') + '" id="rosterTbl"><thead><tr><th style="width:56px">Pos</th><th>Player</th><th class="r">Points</th><th class="r">Starts</th></tr></thead><tbody>'
          + roster.map(([nm, v], i) => '<tr' + (i >= N ? ' class="tm-xr"' : '') + '><td><span class="tm-pos">' + (v.pos === 'W/R/T' ? 'FLEX' : v.pos) + '</span></td><td class="tm-rpl">' + esc(nm) + '</td><td class="r">' + v.pts.toFixed(1) + '</td><td class="r">' + v.st + '</td></tr>').join('')
          + '</tbody></table></div>' + (extra > 0 ? '<button class="tm-tgl" id="rosterToggle">Show full roster (' + extra + ' more) ▾</button>' : '') + '</div>';
      }

      function scheduleHtml(yr) {
        const sched = D.schedulesByYear[yr] || [];
        const lu = (cache[yr] && cache[yr][D.key]) || {};
        let rows = '';
        for (const g of sched) {
          const clickable = g.wk != null && lu[g.wk] && cache[yr][g.opp] && cache[yr][g.opp][g.wk];
          const score = g.pf.toFixed(2) + '–' + g.pa.toFixed(2);
          const scoreCell = clickable ? '<a class="tm-score" data-wk="' + g.wk + '" data-opp="' + esc(g.opp) + '">' + score + '</a>' : '<span class="tm-scoredim">' + score + '</span>';
          rows += '<tr class="' + (g.playoff ? 'tm-po-row' : '') + '"><td class="r tm-wkc">' + (g.playoff ? '<span class="tm-po">' + esc(g.label || 'PO') + '</span>' : (g.wk != null ? g.wk : '')) + '</td>'
            + '<td>' + esc(teamOf(yr, g.opp)) + ' <span class="sub">' + esc(nameOf(g.opp)) + '</span></td>'
            + '<td><span class="tm-wl ' + g.res + '">' + g.res + '</span></td><td class="r">' + scoreCell + '</td></tr>';
        }
        return '<div class="card"><div class="tm-eyebrow">' + yr + ' Schedule / Results</div>'
          + '<div class="table-scroll"><table class="stbl"><thead><tr><th class="r">Wk</th><th>Opponent</th><th>Result</th><th class="r">Score</th></tr></thead><tbody>' + rows + '</tbody></table></div>'
          + '<p class="sub" style="margin-top:10px;font-style:italic">Click a score to open the full matchup lineup.</p></div>';
      }

      function lineupCard(yr, mk, wk, isWin) {
        const l = cache[yr] && cache[yr][mk] && cache[yr][mk][wk];
        if (!l) return '<div class="card tm-lu"><div class="tm-luh"><span class="tm-lun">' + esc(teamOf(yr, mk)) + '</span></div><p class="sub">No lineup data.</p></div>';
        let rows = '';
        for (const [slot, nm, pts] of l.s) rows += '<tr><td class="tm-slot">' + esc(slot) + '</td><td>' + esc(nm || '—') + '</td><td class="r">' + pts.toFixed(2) + '</td></tr>';
        rows += '<tr class="tm-dv"><td colspan="3">Bench</td></tr>';
        for (const [slot, nm, pts] of l.b) rows += '<tr class="tm-bnch"><td class="tm-slot">' + esc(slot) + '</td><td>' + esc(nm || '—') + '</td><td class="r">' + pts.toFixed(2) + '</td></tr>';
        return '<div class="card tm-lu' + (isWin ? ' tm-win' : '') + '"><div class="tm-luh"><span class="tm-lun">' + esc(teamOf(yr, mk)) + ' <span class="sub">' + esc(nameOf(mk)) + '</span></span><span class="tm-lut">' + l.tot.toFixed(2) + '</span></div>'
          + '<div class="table-scroll"><table class="stbl"><tbody>' + rows + '</tbody></table></div></div>';
      }

      function showTeam(yr) {
        $('teamName').textContent = teamOf(yr, D.key);
        $('body').innerHTML = rosterHtml(yr) + scheduleHtml(yr);
        const rtg = $('rosterToggle');
        if (rtg) { const more = rtg.textContent; rtg.onclick = () => { const col = $('rosterTbl').classList.toggle('collapsed'); rtg.textContent = col ? more : 'Collapse to top 10 ▴'; }; }
        document.querySelectorAll('.tm-score[data-wk]').forEach((el) => el.onclick = () => showMatchup(yr, Number(el.dataset.wk), el.dataset.opp));
      }
      function showMatchup(yr, wk, opp) {
        const meT = cache[yr][D.key][wk], opT = cache[yr][opp][wk];
        const meWin = meT.tot >= opT.tot;
        $('body').innerHTML = '<a class="tm-back" id="mback">← ' + esc(D.name) + ' · ' + yr + '</a>'
          + '<div class="tm-eyebrow" style="margin:2px 0 2px">' + yr + ' · Week ' + wk + '</div>'
          + '<h2 class="tm-mtitle">' + esc(teamOf(yr, D.key)) + ' <span class="sub" style="font-weight:400">vs</span> ' + esc(teamOf(yr, opp)) + '</h2>'
          + '<div class="tm-two">' + lineupCard(yr, D.key, wk, meWin) + lineupCard(yr, opp, wk, !meWin) + '</div>';
        $('mback').onclick = () => showTeam(yr);
        window.scrollTo(0, 0);
      }
      async function selectSeason(yr, open) {
        $('body').innerHTML = '<div class="sub" style="padding:20px 0">Loading ' + yr + '…</div>';
        await loadSeason(yr);
        showTeam(yr);
        if (open && cache[yr][D.key] && cache[yr][D.key][open.wk] && cache[yr][open.opp] && cache[yr][open.opp][open.wk]) showMatchup(yr, open.wk, open.opp);
      }

      $('seasonSel').addEventListener('change', (e) => selectSeason(Number(e.target.value)));

      // Deep-link support: /teams/<key>/?season=YYYY[&week=N&opp=<key>]
      const params = new URLSearchParams(location.search);
      const ps = Number(params.get('season'));
      const startYr = D.years.includes(ps) ? ps : D.years[0];
      $('seasonSel').value = String(startYr);
      const pw = Number(params.get('week')), po = params.get('opp');
      selectSeason(startYr, (pw && po && D.mgrNames[po]) ? { wk: pw, opp: po } : null);
    })();
  </script>

  <style is:global>
    /* Teams pages. Global (not scoped) because roster/schedule/matchup tables are
       injected via innerHTML and would miss Astro's scoped-style attribute. Base
       look comes from the site-wide .stbl / .card / .sub; tm-* adds the extras. */
    .tm-back { display: inline-block; font-weight: 700; font-size: 13px; margin-bottom: 12px; }
    .tm-ovcard { margin-bottom: 4px; }
    .tm-ov { display: grid; grid-template-columns: repeat(auto-fit, minmax(84px, 1fr)); gap: 12px; }
    .tm-st { text-align: center; }
    .tm-st .tm-v { font-size: 22px; font-weight: 900; color: var(--purple-700); }
    .tm-st .tm-l { font-size: 10px; letter-spacing: .5px; text-transform: uppercase; color: var(--muted); }
    .tm-ctrl { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin: 18px 0 4px; }
    .tm-ctrl label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--purple-700); }
    .tm-ctrl select { padding: 8px 12px; border: 2px solid var(--purple-700); border-radius: 9px; font-size: 15px; font-weight: 800; color: var(--purple-900); background: #fff; cursor: pointer; }
    .tm-eyebrow { font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--muted); font-weight: 700; margin-bottom: 8px; }

    #body .stbl { margin-top: 0; }
    .tm-rost tbody td { padding: 10px 12px; }
    .tm-rpl { font-weight: 700; }
    .tm-pos { display: inline-block; min-width: 42px; font-size: 10px; font-weight: 800; letter-spacing: .5px; color: var(--purple-500); text-align: center; border: 1px solid var(--line); border-radius: 5px; padding: 2px 4px; }
    .tm-rost.collapsed .tm-xr { display: none; }
    .tm-tgl { margin-top: 10px; background: transparent; border: 1px solid var(--line); border-radius: 8px; color: var(--purple-700); font-weight: 800; font-size: 12.5px; padding: 7px 14px; cursor: pointer; }
    .tm-tgl:hover { background: #faf8ff; }

    .stbl tbody tr.tm-po-row { background: #faf8ff; }
    .tm-wkc { color: var(--muted); }
    .tm-wl { font-weight: 800; border-radius: 5px; padding: 1px 7px; font-size: 12px; }
    .tm-wl.W { background: rgba(22,163,74,.14); color: var(--win); }
    .tm-wl.L { background: rgba(220,38,38,.12); color: var(--loss); }
    .tm-wl.T { background: rgba(138,131,166,.2); color: var(--muted); }
    .tm-score { font-weight: 800; font-variant-numeric: tabular-nums; white-space: nowrap; cursor: pointer; }
    .tm-scoredim { font-weight: 800; font-variant-numeric: tabular-nums; color: var(--muted); }
    .tm-po { font-size: 10px; text-transform: uppercase; letter-spacing: .5px; color: #e65100; font-weight: 800; }

    .tm-two { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 640px) { .tm-two { grid-template-columns: 1fr; } }
    .tm-mtitle { font-size: 20px; font-weight: 900; color: var(--purple-900); margin-bottom: 12px; }
    .tm-lu .tm-luh { display: flex; justify-content: space-between; align-items: baseline; border-bottom: 2px solid var(--purple-700); padding-bottom: 6px; margin-bottom: 6px; }
    .tm-lu .tm-lun { font-weight: 900; color: var(--purple-900); font-size: 15px; }
    .tm-lu .tm-lut { font-weight: 900; font-size: 20px; color: var(--purple-700); font-variant-numeric: tabular-nums; }
    .tm-lu td.tm-slot { font-weight: 800; color: var(--purple-500); width: 52px; font-size: 11px; }
    .tm-lu tbody tr.tm-bnch td { color: var(--muted); }
    .tm-lu tbody tr.tm-dv td { padding: 4px 12px; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); background: #faf8ff; }
    .tm-lu.tm-win { outline: 2px solid var(--gold); }
  </style>
</Base>
