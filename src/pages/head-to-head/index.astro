---
import Base from '../../layouts/Base.astro';
import { h2h as h2hRaw } from '../../lib/data.ts';

const h2hData = (h2hRaw as any).h2h as Record<string, any>;
const managerMap = (h2hRaw as any).managers as Record<string, { label: string; since: string }>;
const mgrs = Object.entries(managerMap)
  .map(([key, v]) => ({ key, label: v.label, since: v.since }))
  .sort((a, b) => a.label.localeCompare(b.label));
---
<Base title="Head-to-Head" subtitle="Pick any two managers to see their all-time head-to-head history.">
  <div class="card">
    <div class="pickers">
      <div class="picker">
        <label>Manager 1</label>
        <select id="mgr1">
          <option value="">Select manager…</option>
          {mgrs.map((m) => <option value={m.key}>{m.label} (Since '{String(m.since).slice(-2)}')</option>)}
        </select>
      </div>
      <div class="vs">vs</div>
      <div class="picker gold">
        <label>Manager 2</label>
        <select id="mgr2">
          <option value="">Select manager…</option>
          {mgrs.map((m) => <option value={m.key}>{m.label} (Since '{String(m.since).slice(-2)}')</option>)}
        </select>
      </div>
    </div>

    <div id="prompt" class="prompt">Select two managers above to see their all-time head-to-head record.</div>

    <div id="result" style="display:none;">
      <div class="score-row">
        <div class="score-card p"><div id="m1name" class="sc-name"></div><div id="m1wins" class="sc-wins">—</div><div class="sc-lbl">All-Time Wins</div></div>
        <div class="score-mid">ALL-TIME<br/>HEAD-TO-HEAD</div>
        <div class="score-card g"><div id="m2name" class="sc-name"></div><div id="m2wins" class="sc-wins">—</div><div class="sc-lbl">All-Time Wins</div></div>
      </div>
      <div class="table-scroll">
        <table class="stbl">
          <thead><tr><th>Stat</th><th id="m1col" class="r">Manager 1</th><th id="m2col" class="r">Manager 2</th></tr></thead>
          <tbody>
            <tr><td>All-Time H2H Record</td><td class="r" id="r-rec1">—</td><td class="r" id="r-rec2">—</td></tr>
            <tr class="at"><td>Total Points vs Each Other</td><td class="r" id="r-pf1">—</td><td class="r" id="r-pf2">—</td></tr>
            <tr><td>Avg Points Per Game</td><td class="r" id="r-avg1">—</td><td class="r" id="r-avg2">—</td></tr>
            <tr class="at"><td>Biggest Win (points)</td><td class="r" id="r-big1">—</td><td class="r" id="r-big2">—</td></tr>
            <tr><td>Last Matchup Result</td><td class="r" id="r-last1">—</td><td class="r" id="r-last2">—</td></tr>
            <tr class="at"><td>Playoff Matchups</td><td colspan="2" class="r" id="r-playoff" style="text-align:center;">—</td></tr>
            <tr><td>Seasons Overlapping</td><td colspan="2" class="r" id="r-seasons" style="text-align:center;">—</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ h2hData, managerMap }}>
    function getH2H(a, b) {
      if (h2hData[a] && h2hData[a][b]) return h2hData[a][b];
      if (h2hData[b] && h2hData[b][a]) {
        const d = h2hData[b][a];
        return {
          w1: d.w2, w2: d.w1, pf1: d.pf2, pf2: d.pf1, big1: d.big2, big2: d.big1,
          last: d.last ? { winner: d.last.winner, score1: d.last.score2, score2: d.last.score1, season: d.last.season } : null,
          playoffs: d.playoffs, seasons: d.seasons,
        };
      }
      return null;
    }
    const nameOf = (k) => (managerMap[k] ? managerMap[k].label : k);
    const $ = (id) => document.getElementById(id);

    function update() {
      const a = $('mgr1').value, b = $('mgr2').value;
      const result = $('result'), prompt = $('prompt');
      if (!a || !b || a === b) {
        result.style.display = 'none';
        prompt.style.display = 'block';
        prompt.textContent = a && b && a === b ? 'Please pick two different managers.' : 'Select two managers above to see their all-time head-to-head record.';
        return;
      }
      const d = getH2H(a, b);
      const mA = nameOf(a), mB = nameOf(b);
      $('m1name').textContent = mA; $('m2name').textContent = mB;
      $('m1col').textContent = mA; $('m2col').textContent = mB;
      if (!d) {
        result.style.display = 'none';
        prompt.style.display = 'block';
        prompt.textContent = mA + ' and ' + mB + ' have no recorded meetings.';
        return;
      }
      result.style.display = 'block';
      prompt.style.display = 'none';
      const tot = d.w1 + d.w2;
      $('m1wins').textContent = d.w1; $('m2wins').textContent = d.w2;
      $('r-rec1').textContent = d.w1 + '-' + d.w2; $('r-rec2').textContent = d.w2 + '-' + d.w1;
      $('r-pf1').textContent = d.pf1.toFixed(2); $('r-pf2').textContent = d.pf2.toFixed(2);
      $('r-avg1').textContent = tot ? (d.pf1 / tot).toFixed(1) : '—';
      $('r-avg2').textContent = tot ? (d.pf2 / tot).toFixed(1) : '—';
      $('r-big1').textContent = d.big1 ? d.big1.toFixed(2) : '—';
      $('r-big2').textContent = d.big2 ? d.big2.toFixed(2) : '—';
      if (d.last) {
        const lsn = "'" + d.last.season;
        $('r-last1').textContent = (d.last.winner === a ? 'W ' : 'L ') + d.last.score1.toFixed(2) + ' · ' + lsn;
        $('r-last2').textContent = (d.last.winner === b ? 'W ' : 'L ') + d.last.score2.toFixed(2) + ' · ' + lsn;
      } else { $('r-last1').textContent = '—'; $('r-last2').textContent = '—'; }
      $('r-playoff').textContent = d.playoffs ? d.playoffs + ' playoff meeting' + (d.playoffs > 1 ? 's' : '') : 'None';
      $('r-seasons').textContent = d.seasons ? d.seasons + ' season' + (d.seasons > 1 ? 's' : '') : '—';
    }
    $('mgr1').addEventListener('change', update);
    $('mgr2').addEventListener('change', update);
  </script>

  <style>
    .pickers { display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 20px; }
    .picker { flex: 1; min-width: 180px; }
    .picker label { display: block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--purple-700); margin-bottom: 6px; }
    .picker select { width: 100%; padding: 10px 12px; border: 2px solid var(--purple-700); border-radius: 8px; font-size: 14px; font-weight: 700; color: var(--purple-900); background: #fff; cursor: pointer; }
    .picker.gold select { border-color: var(--gold); }
    .vs { font-size: 24px; font-weight: 900; color: var(--purple-900); padding-bottom: 8px; }
    .prompt { text-align: center; padding: 32px; color: #bbb; font-size: 14px; }
    .score-row { display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px; align-items: center; margin-bottom: 24px; }
    .score-card { text-align: center; border-radius: 12px; padding: 18px; }
    .score-card.p { background: #f7f3ff; border: 2px solid var(--purple-700); }
    .score-card.g { background: #fff8e1; border: 2px solid var(--gold); }
    .sc-name { font-size: 18px; font-weight: 900; color: var(--purple-900); }
    .sc-wins { font-size: 46px; font-weight: 900; line-height: 1; color: var(--purple-700); }
    .score-card.g .sc-wins { color: #e65100; }
    .sc-lbl { font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: 1px; }
    .score-mid { text-align: center; font-size: 12px; font-weight: 700; color: #aaa; }
  </style>
</Base>
